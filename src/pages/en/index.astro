---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../i18n.ts';
const t = translations.en;
const lang = 'en';

const projects = [
  { title: 'Gospel Celebrations Friday Delivery', videoId: 'fvcC-OiFOXM', vertical: false, tag: 'Concert', year: '2026' },
  { title: 'Office Amelia Video', videoId: '2zAnE4BHG3g', vertical: true, tag: 'Social Media', year: '2026' },
  { title: 'Barber Video', videoId: '7gZLxHgUQx8', vertical: true, tag: 'Brand Film', year: '2026' },
  { title: 'Martabak', videoId: '9nALKayuaE0', vertical: true, tag: 'Commercial', year: '2026' },
  { title: 'Sabajo Vision', videoId: 'a-9kq35OiDQ', vertical: true, tag: 'Community', year: '2026' },
  { title: 'Together We Build', videoId: 'otjwjZ9A7Gc', vertical: true, tag: 'Event', year: '2026' },
  { title: 'Office Website 4K', videoId: 'oLuet3RdY1A', vertical: false, tag: 'Corporate', year: '2026' },
];
---

<Layout t={t} lang="en" pageTitle="Goldfishstudio" year="2026">

  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <iframe
        src="https://player.vimeo.com/video/1169208987?h=a7a6a855d2&autoplay=1&loop=1&muted=1&background=1"
        title="Goldfishstudio background"
        allow="autoplay; fullscreen"
        loading="lazy"
      />
    </div>
    <div class="hero-overlay" />
    <div class="container hero-content">
      <div class="hero-inner">
        <div class="hero-eyebrow" set:html={t.hero.eyebrow} />
        <h1 class="hero-title" set:html={t.hero.title} />
        <p class="hero-sub" set:html={t.hero.sub} />
        <div class="hero-actions">
          <a href="/work" class="btn btn-primary" set:html={t.hero.cta1} />
          <a href="/contact" class="btn btn-ghost" set:html={t.hero.cta2} />
        </div>
      </div>
    </div>
  </section>

  <section id="work">
    <div class="container">
      <div class="eyebrow" set:html={t.work.eyebrow} />
      <h2 class="heading" set:html={t.work.heading} />
      <div class="video-grid">
        {projects.map((p) => (
          <article class:list={["video-card", p.vertical && "vertical"]}>
            <div class:list={["video-card-media", p.vertical && "vertical"]} data-video={p.videoId} style="cursor:pointer;">
              <img src={`https://img.youtube.com/vi/${p.videoId}/maxresdefault.jpg`} alt={p.title} class="video-poster" loading="lazy" />
              <button class="play-btn" aria-label={`Play ${p.title}`}>
                <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              </button>
              <div class="video-thumb-loading" style="display:none;"></div>
              <iframe class:list={["video-iframe", p.vertical && "vertical"]} title={p.title} allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share" allowfullscreen referrerpolicy="strict-origin-when-cross-origin" loading="lazy" style="display:none;" onload="this.style.display='block';this.parentElement.querySelector('.video-thumb-loading').style.display='none';this.parentElement.querySelector('.video-poster').style.display='none';this.parentElement.querySelector('.play-btn').style.display='none';"></iframe>
            </div>
            <div class="video-meta">
              <span class="video-tag" set:html={p.tag} />
              <span class="video-meta-dot"></span>
              <span class="video-year" set:html={p.year} />
            </div>
            <div class="video-title" set:html={p.title} />
          </article>
        ))}
      </div>
    </div>
  </section>

  <div class="cta-band">
    <div class="container">
      <h2 class="heading" set:html={t.cta.heading} />
      <p class="lede" style="margin:0 auto 2.5rem;" set:html={t.cta.sub} />
      <a href="/en/contact" class="btn btn-primary" set:html={t.cta.btn} />
    </div>
  </div>

  <script>
    document.querySelectorAll('.video-card-media').forEach(card => {
      card.addEventListener('click', (e) => {
        // Prevent triggering if clicking the link wrapper (optional, but good for safety)
        const videoId = card.dataset.video;
        if (!videoId) return;
        const iframe = card.querySelector('iframe');
        const poster = card.querySelector('.video-poster');
        const btn = card.querySelector('.play-btn');
        const loader = card.querySelector('.video-thumb-loading');
        
        poster.style.display = 'none';
        btn.style.display = 'none';
        loader.style.display = 'flex';
        
        iframe.src = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&fs=0&modestbranding=1`;
        iframe.style.display = 'block';
      });
    });
  </script>

</Layout>
