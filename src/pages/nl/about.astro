---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../i18n.ts';
const t = translations.nl;
---

<Layout t={t} lang="nl" pageTitle="Over mij — Goldfishstudio" year="2026">

  <section class="container" style="padding-top: 8rem;">
    <div class="editorial">
      <div>
        <div class="eyebrow" set:html={t.about.eyebrow} />
        <h1 class="heading" style="font-size: clamp(2rem, 5vw, 3.5rem);" set:html={t.about.heading} />
        <p set:html={t.about.p1} />
        <p set:html={t.about.p2} />
        <p set:html={t.about.p3} />
      </div>
      <div class="editorial-image" aria-hidden="true">
        <div class="video-thumb-placeholder">Portretfoto</div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section style="border-top: 1px solid var(--border);">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-num">20+</div>
          <div class="stat-label">Projecten voltooid</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">2</div>
          <div class="stat-label">Jaar ervaring</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">4K</div>
          <div class="stat-label">Alle projecten in 4K</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">100%</div>
          <div class="stat-label">Klanttevredenheid</div>
        </div>
      </div>
    </div>
  </section>

</Layout>
