---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../i18n.ts';
const t = translations.nl;

const featured = {
  title: 'Restaurant Promo — De Kas',
  tag: 'Commercial',
  year: '2026',
  video: '1169209749',
};

const projects = [
  { title: 'Project 01', tag: 'Commercial', year: '2026', video: '1169208960' },
  { title: 'Project 02', tag: 'Muziekvideo', year: '2026', video: '1169208935' },
  { title: 'Project 03', tag: 'Merkenfilm', year: '2025', video: '1169209569' },
  { title: 'Social Media — Bloom Coffee', tag: 'Social Media', year: '2025', video: null },
  { title: 'Productlancering — Waka Waka', tag: 'Commercial', year: '2025', video: null },
  { title: 'Evenement — AfroTech', tag: 'Evenement', year: '2024', video: null },
];
---

<Layout t={t} lang="nl" pageTitle="Werk — Goldfishstudio" year="2026">

  <section class="container" style="padding-top: 8rem;">
    <div class="eyebrow" set:html={t.work.eyebrow} />
    <h1 class="heading" style="font-size: clamp(2rem, 5vw, 3.5rem);" set:html={t.work.heading} />

    <!-- Uitgelichte video -->
    <div style="margin-top: 3rem;">
      <article class="video-card">
        <div class="video-thumb" style="aspect-ratio:16/9;">
          {featured.video
            ? <iframe src={`https://player.vimeo.com/video/${featured.video}`} title={featured.title} allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share" allowfullscreen referrerpolicy="strict-origin-when-cross-origin" loading="lazy" />
            : <div class="video-thumb-placeholder">VIDEO&nbsp;PLACEHOLDER</div>
          }
        </div>
        <div class="video-meta">
          <span class="video-tag">{featured.tag}</span>
          <span class="video-meta-dot"></span>
          <span class="video-year">{featured.year}</span>
        </div>
        <div class="video-title">{featured.title}</div>
      </article>
    </div>

    <!-- Meer werk -->
    <div style="margin-top: 4rem;">
      <div class="eyebrow" style="font-size:.65rem; margin-bottom:1.5rem;">MEER WERK</div>
      <div class="video-grid" style="grid-template-columns:repeat(2,1fr);">
        {projects.map((p) => (
          <article class="video-card">
            <div class="video-thumb">
              {p.video
                ? <iframe src={`https://player.vimeo.com/video/${p.video}`} title={p.title} allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share" allowfullscreen referrerpolicy="strict-origin-when-cross-origin" loading="lazy" />
                : <div class="video-thumb-placeholder">VIDEO&nbsp;PLACEHOLDER</div>
              }
            </div>
            <div class="video-meta">
              <span class="video-tag">{p.tag}</span>
              <span class="video-meta-dot"></span>
              <span class="video-year">{p.year}</span>
            </div>
            <div class="video-title">{p.title}</div>
          </article>
        ))}
      </div>
    </div>
  </section>

</Layout>
