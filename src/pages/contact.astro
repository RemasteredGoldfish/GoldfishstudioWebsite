---
import Layout from '../layouts/Layout.astro';
---

<Layout pageTitle="Contact" year="2026">

  <section class="container" style="padding-top: 8rem; padding-bottom: 4rem;">
    <div class="contact-grid">
      <div>
        <div class="section-label">Contact</div>
        <h1 class="section-title" style="font-size: clamp(2rem, 5vw, 3.5rem);">Let's work<br/>together.</h1>
        <p class="section-desc">
          Got a project in mind? Reach out and I'll get back to you within 24 hours.
          If it's a fire, put "URGENT" in the subject.
        </p>

        <div style="margin-top: 2.5rem;">
          <div class="contact-row">
            <strong>E-mail</strong>
            <a href="mailto:info@goldfishstudio.nl">info@goldfishstudio.nl</a>
          </div>
          <div class="contact-row">
            <strong>Location</strong>
            The Netherlands
          </div>
          <div class="contact-row">
            <strong>BTW</strong>
            NL005113528B68
          </div>
          <div class="contact-row">
            <strong>KVK</strong>
            [Your KVK number]
          </div>
        </div>
      </div>

      <form class="contact-form" action="mailto:info@goldfishstudio.nl" method="post" enctype="text/plain">
        <div class="field">
          <label for="name">Your name</label>
          <input type="text" id="name" name="name" placeholder="John Doe" required />
        </div>
        <div class="field">
          <label for="email">E-mail</label>
          <input type="email" id="email" name="email" placeholder="john@example.com" required />
        </div>
        <div class="field">
          <label for="type">Project type</label>
          <input type="text" id="type" name="type" placeholder="Commercial / Music video / Event / Other" />
        </div>
        <div class="field">
          <label for="message">Tell me about your project</label>
          <textarea id="message" name="message" placeholder="What do you need filmed? Any references, deadlines, or specific requirements?" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary" style="align-self: flex-end;">Send message</button>
      </form>
    </div>
  </section>

</Layout>
