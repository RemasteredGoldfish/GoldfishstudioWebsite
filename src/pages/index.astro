---
import Layout from '../layouts/Layout.astro';

const projects = [
  { title: 'De Kas — Farm to Table', tag: 'Commercial', year: '2026', embed: null, placeholder: true },
  { title: 'LUWAM — Night Drive', tag: 'Music Video', year: '2026', embed: null, placeholder: true },
  { title: 'Nordrecht — Made with Care', tag: 'Brand Film', year: '2025', embed: null, placeholder: true },
  { title: 'Bloom Coffee — Morning Ritual', tag: 'Social Media', year: '2025', embed: null, placeholder: true },
];
---

<Layout pageTitle="Goldfishstudio — Cinematic Videography">

  <!-- ── Hero ── -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-eyebrow fade-up">Videography &amp; Film Production — Netherlands</div>
        <h1 class="hero-title fade-up d1">
          I create <em>cinematic videos</em> that tell your story with emotion and intent.
        </h1>
        <p class="hero-sub fade-up d2">
          I'm a freelance videographer based in the Netherlands. I help brands,
          artists, and businesses connect with their audience through visual
          storytelling — from concept to final cut.
        </p>
        <div class="hero-actions fade-up d3">
          <a href="/work" class="btn btn-primary">View my work</a>
          <a href="/contact" class="btn btn-ghost">Get in touch →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Selected Work ── -->
  <section id="work">
    <div class="container">
      <div class="eyebrow">Selected Work</div>
      <h2 class="heading" style="margin-bottom: 3rem;">
        Recent <em>projects</em>.
      </h2>

      <div class="video-grid">
        {projects.map((p, i) => (
          <article class="video-card fade-up" style={`animation-delay: ${i * 0.12}s`}>
            <div class="video-thumb">
              {p.embed
                ? <iframe src={p.embed} title={p.title} loading="lazy" allowfullscreen style="width:100%;height:100%;border:none;" />
                : <div class="video-thumb-placeholder">VIDEO&nbsp;PLACEHOLDER</div>
              }
            </div>
            <div class="video-meta">
              <span class="video-tag">{p.tag}</span>
              <span class="video-meta-dot"></span>
              <span class="video-year">{p.year}</span>
            </div>
            <div class="video-title">{p.title}</div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── About / Story (editorial) ── -->
  <section style="border-top: 1px solid var(--border);">
    <div class="container">
      <div class="editorial">
        <div class="editorial-text">
          <div class="eyebrow">About</div>
          <h2 class="heading" style="margin-bottom: 2rem;">
            Hi, I'm <em>J. Murray</em>.
          </h2>
          <p>
            I'm a freelance videographer and filmmaker based in the Netherlands.
            I've been creating videos for brands, artists, and businesses who want
            to stand out — not with flashy effects, but with authentic storytelling.
          </p>
          <p>
            I handle everything from start to finish: concept development, directing,
            filming, editing, color grading, and sound design. I keep the process
            simple — we talk, I shoot, I deliver. No unnecessary complexity, just
            great work on time.
          </p>
          <p style="margin-top: 1.5rem;">
            Available for projects across the Netherlands and Europe.
          </p>
        </div>
        <div class="editorial-image">
          <div class="video-thumb-placeholder" style="font-size:.8rem;">
            YOUR<br/>PHOTO<br/>HERE
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Services ── -->
  <section style="border-top: 1px solid var(--border); background: var(--bg-warm);">
    <div class="container" style="padding: 8rem 2rem;">
      <div class="eyebrow">Services</div>
      <h2 class="heading" style="margin-bottom: 3rem;">
        What I <em>offer</em>.
      </h2>
      <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:3rem 4rem; max-width:800px;">
        <div>
          <div class="eyebrow" style="font-size:.65rem;">01</div>
          <h3 style="font-family:var(--font-serif); font-size:1.4rem; font-weight:400; margin-bottom:.6rem;">Commercial Video</h3>
          <p class="lede" style="font-size:.92rem; max-width:none;">Promo videos, social media content, and product showcases designed to convert viewers into customers.</p>
        </div>
        <div>
          <div class="eyebrow" style="font-size:.65rem;">02</div>
          <h3 style="font-family:var(--font-serif); font-size:1.4rem; font-weight:400; margin-bottom:.6rem;">Music Videos</h3>
          <p class="lede" style="font-size:.92rem; max-width:none;">Visual storytelling for artists — cinematic narratives, live performances, and creative concepts.</p>
        </div>
        <div>
          <div class="eyebrow" style="font-size:.65rem;">03</div>
          <h3 style="font-family:var(--font-serif); font-size:1.4rem; font-weight:400; margin-bottom:.6rem;">Brand Films</h3>
          <p class="lede" style="font-size:.92rem; max-width:none;">Documentary-style stories that build trust and show the human side of your brand.</p>
        </div>
        <div>
          <div class="eyebrow" style="font-size:.65rem;">04</div>
          <h3 style="font-family:var(--font-serif); font-size:1.4rem; font-weight:400; margin-bottom:.6rem;">Event Coverage</h3>
          <p class="lede" style="font-size:.92rem; max-width:none;">Capturing the energy and emotion of live events, conferences, and performances.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Testimonial ── -->
  <section style="border-top: 1px solid var(--border);">
    <div class="container">
      <div class="testimonial">
        <div class="testimonial-quote">
          "He didn't just film our story — he <em>understood</em> it. The final video captured exactly what we felt on the day."
        </div>
        <div class="testimonial-author">— Client name, Project type, 2025</div>
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <div class="cta-band">
    <div class="container">
      <h2 class="heading">Got a story to <em>tell</em>?</h2>
      <p class="lede" style="margin:0 auto 2rem;">
        I'd love to hear about your project. Drop me a message and I'll get back
        to you within 24 hours.
      </p>
      <a href="/contact" class="btn btn-primary">Start a project →</a>
    </div>
  </div>

  <!-- ── Process ── -->
  <section style="border-top: 1px solid var(--border);">
    <div class="container">
      <div class="editorial">
        <div class="editorial-text">
          <div class="eyebrow">How I Work</div>
          <h2 class="heading" style="margin-bottom: 2rem;">Simple. <em>Intentional</em>.</h2>
          <p><strong>1. We talk.</strong> You tell me about your project, goals, and vision. I ask questions, suggest ideas, and we agree on the direction.</p>
          <p><strong>2. I film.</strong> Shoot day — I handle everything. You focus on your business while I capture the content. Professional gear, backup equipment, clear communication.</p>
          <p><strong>3. I deliver.</strong> You review the first draft on Frame.io, leave comments, and I revise. After approval, you download the final files. Done.</p>
        </div>
        <div class="editorial-image">
          <div class="video-thumb-placeholder" style="font-size:.8rem;">
            BEHIND<br/>THE<br/>SCENES<br/>PHOTO
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
