---
import Layout from '../layouts/Layout.astro';
import { translations } from '../i18n.ts';
const t = translations.en;

const projects = [
  { title: 'De Kas — Farm to Table', tag: 'Commercial', year: '2026', muxId: null },
  { title: 'LUWAM — Night Drive', tag: 'Music Video', year: '2026', muxId: null },
  { title: 'Nordrecht — Made with Care', tag: 'Brand Film', year: '2025', muxId: null },
  { title: 'Bloom Coffee — Morning Ritual', tag: 'Social Media', year: '2025', muxId: null },
];
---

<Layout t={t} lang="en" pageTitle="Goldfishstudio" year="2026">

  <section class="hero">
    <div class="hero-bg">
      <mux-player
        playback-id="hVmQz5KRnonL02tIOz5KjwW72e82pV6iTiurdqwOnSqU"
        title="Goldfishstudio background"
        muted
        autoplay
        loop
        preload="metadata"
        playsinline
      />
    </div>
    <div class="hero-overlay" />
    <div class="container hero-content">
      <div class="hero-inner">
        <div class="hero-eyebrow" set:html={t.hero.eyebrow} />
        <h1 class="hero-title" set:html={t.hero.title} />
        <p class="hero-sub" set:html={t.hero.sub} />
        <div class="hero-actions">
          <a href="/work" class="btn btn-primary" set:html={t.hero.cta1} />
          <a href="/contact" class="btn btn-ghost" set:html={t.hero.cta2} />
        </div>
      </div>
    </div>
  </section>

  <section id="work">
    <div class="container">
      <div class="eyebrow" set:html={t.work.eyebrow} />
      <h2 class="heading" set:html={t.work.heading} />
      <div class="video-grid">
        {projects.map((p) => (
          <article class="video-card">
            <div class="video-thumb">
              {p.embed
                ? <iframe src={p.embed} title={p.title} loading="lazy" allowfullscreen style="width:100%;height:100%;border:none;" />
                : p.muxId
                  ? <mux-player playback-id={p.muxId} title={p.title} preload="metadata" accent-color="#c4a46e" />
                  : <div class="video-thumb-placeholder">VIDEO&nbsp;PLACEHOLDER</div>
              }
            </div>
            <div class="video-meta">
              <span class="video-tag" set:html={p.tag} />
              <span class="video-meta-dot"></span>
              <span class="video-year" set:html={p.year} />
            </div>
            <div class="video-title" set:html={p.title} />
          </article>
        ))}
      </div>
    </div>
  </section>

  <section style="border-top: 1px solid var(--border);">
    <div class="container">
      <div class="editorial">
        <div class="editorial-text">
          <div class="eyebrow" set:html={t.about.eyebrow} />
          <h2 class="heading" set:html={t.about.heading} />
          <p set:html={t.about.p1} />
          <p set:html={t.about.p2} />
          <p set:html={t.about.p3} />
        </div>
        <div class="editorial-image">
          <div class="video-thumb-placeholder" style="font-size:.8rem">YOUR<br/>PHOTO<br/>HERE</div>
        </div>
      </div>
    </div>
  </section>

  <section style="border-top: 1px solid var(--border); background: var(--bg-warm);">
    <div class="container" style="padding: 8rem 2rem;">
      <div class="eyebrow" set:html={t.services.eyebrow} />
      <h2 class="heading" set:html={t.services.heading} />
      <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:3rem 4rem; max-width:800px;">
        <div>
          <div class="eyebrow" style="font-size:.65rem;">01</div>
          <h3 style="font-family:var(--font-serif); font-size:1.4rem; font-weight:400; margin-bottom:.6rem;" set:html={t.services.s1} />
          <p class="lede" style="font-size:.92rem; max-width:none;" set:html={t.services.s1desc} />
        </div>
        <div>
          <div class="eyebrow" style="font-size:.65rem;">02</div>
          <h3 style="font-family:var(--font-serif); font-size:1.4rem; font-weight:400; margin-bottom:.6rem;" set:html={t.services.s2} />
          <p class="lede" style="font-size:.92rem; max-width:none;" set:html={t.services.s2desc} />
        </div>
        <div>
          <div class="eyebrow" style="font-size:.65rem;">03</div>
          <h3 style="font-family:var(--font-serif); font-size:1.4rem; font-weight:400; margin-bottom:.6rem;" set:html={t.services.s3} />
          <p class="lede" style="font-size:.92rem; max-width:none;" set:html={t.services.s3desc} />
        </div>
        <div>
          <div class="eyebrow" style="font-size:.65rem;">04</div>
          <h3 style="font-family:var(--font-serif); font-size:1.4rem; font-weight:400; margin-bottom:.6rem;" set:html={t.services.s4} />
          <p class="lede" style="font-size:.92rem; max-width:none;" set:html={t.services.s4desc} />
        </div>
      </div>
    </div>
  </section>

  <section style="border-top: 1px solid var(--border);">
    <div class="container">
      <div class="testimonial">
        <div class="testimonial-quote" set:html={t.testimonial.quote} />
        <div class="testimonial-author" set:html={t.testimonial.author} />
      </div>
    </div>
  </section>

  <div class="cta-band">
    <div class="container">
      <h2 class="heading" set:html={t.cta.heading} />
      <p class="lede" style="margin:0 auto 2.5rem;" set:html={t.cta.sub} />
      <a href="/contact" class="btn btn-primary" set:html={t.cta.btn} />
    </div>
  </div>

  <section style="border-top: 1px solid var(--border);">
    <div class="container">
      <div class="editorial">
        <div class="editorial-text">
          <div class="eyebrow" set:html={t.how.eyebrow} />
          <h2 class="heading" set:html={t.how.heading} />
          <p><strong set:html={t.how.h1} /> <span set:html={t.how.h1desc} /></p>
          <p><strong set:html={t.how.h2} /> <span set:html={t.how.h2desc} /></p>
          <p><strong set:html={t.how.h3} /> <span set:html={t.how.h3desc} /></p>
        </div>
        <div class="editorial-image">
          <div class="video-thumb-placeholder" style="font-size:.8rem">BEHIND<br/>THE<br/>SCENES<br/>PHOTO</div>
        </div>
      </div>
    </div>
  </section>

</Layout>
