---
import Layout from '../layouts/Layout.astro';
import { translations } from '../i18n.ts';
const t = translations.nl;
const lang = 'nl';

const projects = [
  { title: 'Gospel Celebrations Friday Delivery', videoId: 'fvcC-OiFOXM', vertical: false, tag: 'Concert', year: '2026' },
  { title: 'Office Amelia Video', videoId: '2zAnE4BHG3g', vertical: true, tag: 'Social Media', year: '2026' },
  { title: 'Barber Video', videoId: '7gZLxHgUQx8', vertical: true, tag: 'Merkenfilm', year: '2026' },
  { title: 'Martabak', videoId: '9nALKayuaE0', vertical: true, tag: 'Commercial', year: '2026' },
  { title: 'Sabajo Vision', videoId: 'a-9kq35OiDQ', vertical: true, tag: 'Community', year: '2026' },
  { title: 'Together We Build', videoId: 'otjwjZ9A7Gc', vertical: true, tag: 'Evenement', year: '2026' },
  { title: 'Office Website 4K', videoId: 'oLuet3RdY1A', vertical: false, tag: 'Corporate', year: '2026' },
];
---

<Layout t={t} lang="nl" pageTitle="Goldfishstudio" year="2026">

  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <iframe
        src="https://player.vimeo.com/video/1169208987?h=a7a6a855d2&autoplay=1&loop=1&muted=1&background=1"
        title="Goldfishstudio achtergrond"
        allow="autoplay; fullscreen"
        loading="lazy"
      />
    </div>
    <div class="hero-overlay" />
    <div class="container hero-content">
      <div class="hero-inner">
        <div class="hero-eyebrow" set:html={t.hero.eyebrow} />
        <h1 class="hero-title" set:html={t.hero.title} />
        <p class="hero-sub" set:html={t.hero.sub} />
        <div class="hero-actions">
          <a href="/nl/work" class="btn btn-primary" set:html={t.hero.cta1} />
          <a href="/nl/contact" class="btn btn-ghost" set:html={t.hero.cta2} />
        </div>
      </div>
    </div>
  </section>

  <section id="work">
    <div class="container">
      <div class="eyebrow" set:html={t.work.eyebrow} />
      <h2 class="heading" set:html={t.work.heading} />
      <div class="video-grid">
        {projects.map((p) => (
          <article class:list={["video-card", p.vertical && "vertical"]}>
            <div class:list={["video-card-media", p.vertical && "vertical"]} data-video={p.videoId} style="cursor:pointer;">
              <img src={`https://img.youtube.com/vi/${p.videoId}/maxresdefault.jpg`} alt={p.title} class="video-poster" loading="lazy" />
              <button class="play-btn" aria-label={`Play ${p.title}`}>
                <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              </button>
              <div class="video-thumb-loading" style="display:none;"></div>
              <iframe class:list={["video-iframe", p.vertical && "vertical"]} title={p.title} allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share" allowfullscreen referrerpolicy="strict-origin-when-cross-origin" loading="lazy" style="display:none;" onload="this.style.display='block';this.parentElement.querySelector('.video-thumb-loading').style.display='none';this.parentElement.querySelector('.video-poster').style.display='none';this.parentElement.querySelector('.play-btn').style.display='none';"></iframe>
            </div>
            <div class="video-meta">
              <span class="video-tag" set:html={p.tag} />
              <span class="video-meta-dot"></span>
              <span class="video-year" set:html={p.year} />
            </div>
            <div class="video-title" set:html={p.title} />
          </article>
        ))}
      </div>
    </div>
  </section>

  <section style="border-top: 1px solid var(--border);">
    <div class="container">
      <div class="editorial">
        <div class="editorial-text">
          <div class="eyebrow" set:html={t.about.eyebrow} />
          <h2 class="heading" set:html={t.about.heading} />
          <p set:html={t.about.p1} />
          <p set:html={t.about.p2} />
          <p set:html={t.about.p3} />
        </div>
        <div class="editorial-image" aria-hidden="true">
          <!-- TODO: Vervang src met je eigen portretfoto (bijv. /images/portret.jpg) -->
          <img src="https://images.unsplash.com/photo-1554048612-387768052bf7?auto=format&fit=crop&w=800&q=80" alt="Portret" class="cinematic-img" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section style="border-top: 1px solid var(--border); background: var(--bg-warm);">
    <div class="container">
      <div class="eyebrow" set:html={t.services.eyebrow} />
      <h2 class="heading" set:html={t.services.heading} />
      <div class="services-grid">
        <div class="service-item">
          <div class="eyebrow">01</div>
          <h3 set:html={t.services.s1} />
          <p set:html={t.services.s1desc} />
        </div>
        <div class="service-item">
          <div class="eyebrow">02</div>
          <h3 set:html={t.services.s2} />
          <p set:html={t.services.s2desc} />
        </div>
        <div class="service-item">
          <div class="eyebrow">03</div>
          <h3 set:html={t.services.s3} />
          <p set:html={t.services.s3desc} />
        </div>
        <div class="service-item">
          <div class="eyebrow">04</div>
          <h3 set:html={t.services.s4} />
          <p set:html={t.services.s4desc} />
        </div>
      </div>
    </div>
  </section>

  <section style="border-top: 1px solid var(--border);">
    <div class="container">
      <div class="testimonial">
        <div class="testimonial-quote" set:html={t.testimonial.quote} />
        <div class="testimonial-author" set:html={t.testimonial.author} />
      </div>
    </div>
  </section>

  <div class="cta-band">
    <div class="container">
      <h2 class="heading" set:html={t.cta.heading} />
      <p class="lede" style="margin:0 auto 2.5rem;" set:html={t.cta.sub} />
      <a href="/nl/contact" class="btn btn-primary" set:html={t.cta.btn} />
    </div>
  </div>

  <section style="border-top: 1px solid var(--border);">
    <div class="container">
      <div class="editorial">
        <div class="editorial-text">
          <div class="eyebrow" set:html={t.how.eyebrow} />
          <h2 class="heading" set:html={t.how.heading} />
          <p><strong set:html={t.how.h1} /> <span set:html={t.how.h1desc} /></p>
          <p><strong set:html={t.how.h2} /> <span set:html={t.how.h2desc} /></p>
          <p><strong set:html={t.how.h3} /> <span set:html={t.how.h3desc} /></p>
        </div>
        <div class="editorial-image" aria-hidden="true">
          <!-- TODO: Vervang src met je eigen behind the scenes foto (bijv. /images/bts.jpg) -->
          <img src="https://images.unsplash.com/photo-1533174072545-7a4b6ad7a6c3?auto=format&fit=crop&w=800&q=80" alt="Achter de schermen" class="cinematic-img" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll('.video-card-media[data-video]').forEach(card => {
      card.addEventListener('click', () => {
        const videoId = card.dataset.video;
        if (!videoId) return;
        const iframe = card.querySelector('iframe');
        const poster = card.querySelector('.video-poster');
        const btn = card.querySelector('.play-btn');
        const loader = card.querySelector('.video-thumb-loading');
        
        poster.style.display = 'none';
        btn.style.display = 'none';
        loader.style.display = 'flex';
        
        iframe.src = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&fs=0&modestbranding=1`;
        iframe.style.display = 'block';
      });
    });
  </script>

</Layout>
