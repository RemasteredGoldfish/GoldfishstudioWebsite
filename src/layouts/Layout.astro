---
const { pageTitle = 'Goldfishstudio', year = '2026' } = Astro.props;
const navLinks = [
  { href: '/work', label: 'Work' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Goldfishstudio — Cinematic videography & film production in the Netherlands." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <title>{pageTitle} — Goldfishstudio</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0c0c0c;
      --bg-warm: #1a1510;
      --fg: #f5f0eb;
      --fg-muted: #a09888;
      --fg-dim: #6a6358;
      --accent: #c4a46e;
      --accent-light: #d4b87a;
      --border: #2a2520;
      --font-serif: 'Cormorant Garamond', Georgia, serif;
      --font-sans: 'Inter', system-ui, sans-serif;
    }

    html { font-size: 16px; scroll-behavior: smooth; }
    body {
      font-family: var(--font-sans);
      background: var(--bg);
      color: var(--fg);
      line-height: 1.7;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }
    a { color: inherit; text-decoration: none; }
    img, video { max-width: 100%; display: block; }

    /* ── Navigation ── */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.5rem 3rem;
      transition: background .4s, backdrop-filter .4s;
    }
    .nav.scrolled {
      background: rgba(12,12,12,.92);
      backdrop-filter: blur(16px);
    }
    .nav-logo {
      font-family: var(--font-serif);
      font-size: 1.5rem; font-weight: 400;
      letter-spacing: .08em;
      color: var(--fg);
    }
    .nav-logo em { color: var(--accent); font-style: italic; }
    .nav-links { display: flex; gap: 2.5rem; list-style: none; align-items: center; }
    .nav-links a {
      font-size: .75rem; font-weight: 500;
      letter-spacing: .12em; text-transform: uppercase;
      color: var(--fg-muted);
      transition: color .3s;
    }
    .nav-links a:hover { color: var(--fg); }
    .nav-links a.active { color: var(--accent); }
    .nav-cta {
      font-size: .75rem; font-weight: 500;
      letter-spacing: .12em; text-transform: uppercase;
      padding: .7rem 1.5rem;
      border: 1px solid var(--border);
      color: var(--fg);
      transition: border-color .3s, color .3s;
    }
    .nav-cta:hover { border-color: var(--accent); color: var(--accent); }

    /* ── Container ── */
    .container { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }
    .container-wide { max-width: 1400px; margin: 0 auto; padding: 0 3rem; }

    /* ── Hero ── */
    .hero {
      min-height: 100vh; display: flex; align-items: center;
      position: relative; padding-top: 6rem;
      background: radial-gradient(ellipse at 30% 60%, var(--bg-warm) 0%, var(--bg) 65%);
    }
    .hero-inner { max-width: 750px; }
    .hero-eyebrow {
      font-size: .7rem; font-weight: 500;
      letter-spacing: .18em; text-transform: uppercase;
      color: var(--accent); margin-bottom: 2rem;
    }
    .hero-title {
      font-family: var(--font-serif);
      font-size: clamp(2.8rem, 6vw, 4.5rem);
      font-weight: 300; line-height: 1.15;
      margin-bottom: 1.8rem;
      color: var(--fg);
    }
    .hero-title em { font-style: italic; color: var(--accent); }
    .hero-sub {
      font-size: 1.05rem; color: var(--fg-muted);
      max-width: 520px; line-height: 1.9;
      margin-bottom: 2.5rem;
    }
    .hero-actions { display: flex; gap: 1.2rem; flex-wrap: wrap; }
    .btn {
      display: inline-flex; align-items: center; gap: .6rem;
      padding: .9rem 2rem; font-family: var(--font-sans);
      font-size: .75rem; font-weight: 500;
      letter-spacing: .12em; text-transform: uppercase;
      transition: all .3s; cursor: pointer;
    }
    .btn-primary {
      background: var(--accent); color: #0c0c0c;
      border: 1px solid var(--accent);
    }
    .btn-primary:hover { background: var(--accent-light); border-color: var(--accent-light); }
    .btn-ghost {
      background: transparent; color: var(--fg);
      border: 1px solid var(--border);
    }
    .btn-ghost:hover { border-color: var(--fg-dim); }

    /* ── Section basics ── */
    section { padding: 8rem 0; }
    .eyebrow {
      font-size: .7rem; font-weight: 500;
      letter-spacing: .18em; text-transform: uppercase;
      color: var(--accent); margin-bottom: 1.5rem;
    }
    .heading {
      font-family: var(--font-serif);
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 300; line-height: 1.25;
      margin-bottom: 1.5rem;
    }
    .heading em { font-style: italic; color: var(--accent); }
    .lede {
      font-size: 1.05rem; color: var(--fg-muted);
      max-width: 560px; line-height: 1.9;
    }

    /* ── Editorial layout (alternating) ── */
    .editorial { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
    .editorial-text p { color: var(--fg-muted); margin-bottom: 1.2rem; font-size: 1rem; line-height: 1.9; }
    .editorial-text p:first-child { color: var(--fg); }
    .editorial-image {
      aspect-ratio: 4/5; background: var(--bg-warm);
      border-radius: 2px; overflow: hidden;
      display: flex; align-items: center; justify-content: center;
      color: var(--fg-dim); font-size: .85rem;
    }
    .editorial-image img { width: 100%; height: 100%; object-fit: cover; }

    /* ── Video grid ── */
    .video-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
    .video-card { cursor: pointer; }
    .video-card:hover .video-thumb img { transform: scale(1.03); }
    .video-card:hover .video-title { color: var(--accent); }
    .video-thumb {
      aspect-ratio: 16/10; overflow: hidden;
      background: var(--bg-warm); border-radius: 2px;
      margin-bottom: 1.2rem;
    }
    .video-thumb img {
      width: 100%; height: 100%; object-fit: cover;
      transition: transform .6s ease;
    }
    .video-thumb-placeholder {
      width: 100%; height: 100%;
      display: flex; align-items: center; justify-content: center;
      color: var(--fg-dim); font-size: .75rem; letter-spacing: .1em;
    }
    .video-meta { display: flex; align-items: center; gap: .5rem; margin-bottom: .4rem; }
    .video-meta-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--fg-dim); }
    .video-tag { font-size: .7rem; color: var(--fg-dim); letter-spacing: .08em; text-transform: uppercase; }
    .video-year { font-size: .7rem; color: var(--fg-dim); }
    .video-title {
      font-family: var(--font-serif);
      font-size: 1.3rem; font-weight: 400;
      line-height: 1.3; transition: color .3s;
    }

    /* ── Testimonial ── */
    .testimonial {
      text-align: center; max-width: 700px; margin: 0 auto;
      padding: 4rem 0;
    }
    .testimonial-quote {
      font-family: var(--font-serif);
      font-size: clamp(1.4rem, 3vw, 2rem);
      font-weight: 300; line-height: 1.5;
      color: var(--fg); margin-bottom: 1.5rem;
    }
    .testimonial-quote em { font-style: italic; color: var(--accent); }
    .testimonial-author { font-size: .8rem; color: var(--fg-dim); letter-spacing: .08em; }

    /* ── CTA band ── */
    .cta-band {
      padding: 5rem 0;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      text-align: center;
    }
    .cta-band .heading { margin-bottom: 1rem; }
    .cta-band .lede { margin: 0 auto 2rem; }

    /* ── Contact ── */
    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; }
    .contact-form { display: flex; flex-direction: column; gap: 1.5rem; }
    .field label {
      display: block; font-size: .7rem; font-weight: 500;
      letter-spacing: .1em; text-transform: uppercase;
      color: var(--fg-muted); margin-bottom: .5rem;
    }
    .field input, .field textarea, .field select {
      width: 100%; padding: .9rem 0;
      background: transparent; border: none;
      border-bottom: 1px solid var(--border);
      color: var(--fg); font-family: var(--font-sans);
      font-size: .95rem; transition: border-color .3s;
    }
    .field input:focus, .field textarea:focus {
      outline: none; border-color: var(--accent);
    }
    .field textarea { min-height: 120px; resize: vertical; }
    .contact-details { display: flex; flex-direction: column; gap: 1.5rem; }
    .contact-item { display: flex; flex-direction: column; gap: .3rem; }
    .contact-item-label { font-size: .7rem; color: var(--fg-dim); letter-spacing: .1em; text-transform: uppercase; }
    .contact-item-value { font-size: 1rem; color: var(--fg); }
    .contact-item-value a:hover { color: var(--accent); }

    /* ── Footer ── */
    footer {
      padding: 3rem 0;
      border-top: 1px solid var(--border);
      display: flex; justify-content: space-between;
      align-items: center; flex-wrap: wrap; gap: 1.5rem;
    }
    .footer-copy { font-size: .75rem; color: var(--fg-dim); letter-spacing: .05em; }
    .footer-links { display: flex; gap: 2rem; list-style: none; }
    .footer-links a { font-size: .75rem; color: var(--fg-dim); letter-spacing: .08em; }
    .footer-links a:hover { color: var(--accent); }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .nav { padding: 1rem 1.5rem; }
      .nav-links { gap: 1.2rem; }
      .nav-links a { font-size: .65rem; }
      .nav-cta { display: none; }
      section { padding: 5rem 0; }
      .editorial, .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
      .video-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    }

    /* Animations */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .fade-up { opacity: 0; animation: fadeUp .9s ease-out forwards; }
    .d1 { animation-delay: .1s; }
    .d2 { animation-delay: .25s; }
    .d3 { animation-delay: .4s; }
    .d4 { animation-delay: .55s; }

    @media (prefers-reduced-motion: reduce) {
      .fade-up { animation: none; opacity: 1; }
    }
  </style>
</head>
<body>
  <nav class="nav" id="nav">
    <a href="/" class="nav-logo">goldfish<em>studio</em></a>
    <ul class="nav-links">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[{ active: currentPath.startsWith(link.href) }]}
          >{link.label}</a>
        </li>
      ))}
      <li><a href="/contact" class="nav-cta">Hire me</a></li>
    </ul>
  </nav>

  <main>
    <slot />
  </main>

  <footer>
    <div class="footer-copy">&copy; {year} Goldfishstudio. All rights reserved.</div>
    <ul class="footer-links">
      <li><a href="mailto:info@goldfishstudio.nl">info@goldfishstudio.nl</a></li>
      <li><a href="/work">Portfolio</a></li>
      <li><a href="/contact">Get in touch</a></li>
    </ul>
  </footer>

  <script>
    // Nav scroll effect
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 80);
    }, { passive: true });
  </script>
</body>
</html>
